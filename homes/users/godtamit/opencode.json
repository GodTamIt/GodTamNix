        },
        "Qwen/Qwen2.5-VL-32B-Instruct": {
          "name": "Qwen2.5 VL 32B Instruct",
          "limit": { "context": 128000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "stepfun-ai/Step-3.5-Flash": {
          "name": "Step-3.5-Flash",
          "limit": { "context": 262144, "output": 262144 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "zai-org/GLM-5.1": {
