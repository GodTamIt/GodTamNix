{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": false
  },
  "disabled_agents": ["hephaestus"],
  "background_task": {
    "providerConcurrency": {
      "minimax-coding-plan": 4
    }
  },
  "experimental": {
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal"
    }
  },
  "agents": {
    "sisyphus": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "high"
    },
    "hephaestus": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "xhigh"
    },
    "oracle": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "xhigh"
    },
    "librarian": {
      "model": "minimax-coding-plan/MiniMax-M3",
      "variant": "thinking"
    },
    "explore": {
      "model": "minimax-coding-plan/MiniMax-M3",
      "variant": "thinking"
    },
    "multimodal-looker": {
      "model": "synthetic-custom/hf:moonshotai/Kimi-K2.6"
    },
    "prometheus": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "high"
    },
    "metis": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "xhigh"
    },
    "momus": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "high"
    },
    "sisyphus-junior": {
      "model": "minimax-coding-plan/MiniMax-M3",
      "variant": "thinking"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "synthetic-custom/hf:moonshotai/Kimi-K2.6"
    },
    "ultrabrain": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "high"
    },
    "deep": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "xhigh"
    },
    "artistry": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "high"
    },
    "quick": {
      "model": "minimax-coding-plan/MiniMax-M3",
      "variant": "none"
    },
    "unspecified-low": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "high"
    },
    "unspecified-high": {
      "model": "synthetic-custom/hf:zai-org/GLM-5.2",
      "variant": "xhigh"
    },
    "writing": {
      "model": "minimax-coding-plan/MiniMax-M3",
      "variant": "thinking"
    }
  }
}
