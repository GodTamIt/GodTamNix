output "HDMI-A-2" {
    mode "3840x2160@120"
    scale 1.5
    variable-refresh-rate
}

// Persistent, named workspaces pinned to the single output.
workspace "browser" { open-on-output "HDMI-A-2"; }
workspace "dev" { open-on-output "HDMI-A-2"; }
workspace "media" { open-on-output "HDMI-A-2"; }
workspace "misc" { open-on-output "HDMI-A-2"; }

window-rule {
    match app-id=r#"(?i)youtube.?music"#
    open-on-workspace "media"
    open-focused false
}

// ─── Permanent workspace keybinds ────────────────────────────────────────────
binds {
    // Focus a workspace by number (order matches the workspace declarations above).
    Mod+1 { focus-workspace "browser"; }
    Mod+2 { focus-workspace "dev"; }
    Mod+3 { focus-workspace "media"; }
    Mod+4 { focus-workspace "misc"; }

    // Move the focused column to a workspace.
    Mod+Shift+1 { move-column-to-workspace "browser"; }
    Mod+Shift+2 { move-column-to-workspace "dev"; }
    Mod+Shift+3 { move-column-to-workspace "media"; }
    Mod+Shift+4 { move-column-to-workspace "misc"; }
}
